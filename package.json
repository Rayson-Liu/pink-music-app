{
  "name": "pink-music",
  "private": true,
  "version": "1.1.0",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "electron . --no-sandbox",
    "electron:build": "electron-builder"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "cookie": "^0.7.2",
    "es-toolkit": "^1.39.10",
    "lowdb": "^7.0.1",
    "moment": "^2.30.1",
    "spark-md5": "^3.0.2",
    "vue": "^3.5.32",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "electron": "^20.0.0",
    "electron-builder": "^24.0.0",
    "vite": "^8.0.4"
  },
  "build": {
    "appId": "com.pinkmusic.app",
    "productName": "Pink Music",
    "compression": "maximum",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      {
        "from": "dist",
        "to": "dist",
        "filter": ["index.html", "assets/**/*"]
      },
      "pink.png"
    ],
    "mac": {
      "target": "dmg",
      "icon": "pink.png"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "nsis",
          "arch": ["arm64"]
        }
      ],
      "icon": "pink.png"
    }
  }
}
